# «Decaf» — vLLM OpenAI server image (vLLM + entrypoint; параметры только через -e, без /llm-configs).
#
# Base: PyTorch / CUDA (deniskocs/core:server-base-0.1.0).
FROM deniskocs/core:server-base-0.1.0

# NVFP4 (FlashInfer sm_120) JIT-compiles CUDA kernels on first start; runtime base has no nvcc.
# Align libcublas with -dev (runtime image pins an older libcublas-12-8).
RUN apt-get update && apt-get install -y --no-install-recommends --allow-change-held-packages \
    libcublas-12-8 \
    cuda-nvcc-12-8 \
    libcurand-dev-12-8 \
    libcublas-dev-12-8 \
    ninja-build \
    g++ \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN . /app/venv/bin/activate && \
    pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir "vllm==0.19.1" --extra-index-url https://download.pytorch.org/whl/cu129 && \
    pip install --no-cache-dir "bitsandbytes>=0.48.1" && \
    pip install --no-cache-dir torch-c-dlpack-ext && \
    pip cache purge && \
    rm -rf ~/.cache/pip

COPY docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

ENV CUDA_VISIBLE_DEVICES=0
ENV PYTORCH_ALLOC_CONF=expandable_segments:True
ENV HOST=0.0.0.0

EXPOSE 8000

ENTRYPOINT ["/bin/bash", "/docker-entrypoint.sh"]
