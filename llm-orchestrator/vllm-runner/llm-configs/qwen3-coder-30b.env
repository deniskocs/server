# Конфигурация для Qwen Qwen3-Coder-30B-A3B-Instruct модели
DEFAULT_MODEL_NAME=Qwen/Qwen3-Coder-30B-A3B-Instruct
SERVED_MODEL_NAME=Qwen/Qwen3-Coder-30B-A3B-Instruct

PORT=8000
HOST=0.0.0.0

# Параметры vLLM
# MoE модель, специализирована на кодогенерации
VLLM_QUANTIZATION=
VLLM_MAX_MODEL_LEN=128000
# dtype не указываем, vLLM автоматически определит тип данных из модели
VLLM_DTYPE=
VLLM_GPU_MEMORY_UTILIZATION=0.85
VLLM_ENABLE_AUTO_TOOL_CHOICE=true
VLLM_TOOL_CALL_PARSER=llama3_json
