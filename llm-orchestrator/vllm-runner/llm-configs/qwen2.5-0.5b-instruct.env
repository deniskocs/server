# Маленькая тестовая модель: Qwen2.5-0.5B-Instruct (HF, Apache-2.0)
# https://huggingface.co/Qwen/Qwen2.5-0.5B-Instruct
# Поднимается в vLLM; клиенты OpenAI (OpenAI Python / curl / оркестратор) — на /v1/chat/completions
DEFAULT_MODEL_NAME=Qwen/Qwen2.5-0.5B-Instruct
SERVED_MODEL_NAME=qwen2.5-0.5b-instruct

PORT=8000
HOST=0.0.0.0

# Параметры vLLM
VLLM_QUANTIZATION=
VLLM_MAX_MODEL_LEN=32768
VLLM_DTYPE=
# 0.5B — мало VRAM; поднемай при OOM
VLLM_GPU_MEMORY_UTILIZATION=0.35
VLLM_ENABLE_AUTO_TOOL_CHOICE=true
# Qwen2 / Hermes-стиль tool calls (если tool choice не нужен — можно отключить enable_auto_tool_choice)
VLLM_TOOL_CALL_PARSER=hermes
