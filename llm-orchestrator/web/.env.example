# Production build (CI/local): orchestrator API in k8s.
# VITE_API_BASE_URL=https://api.llms.chilik.net
# Dev: leave empty — Vite proxies /api → http://127.0.0.1:8765

# Keycloak OIDC (defaults match infra/k8s/llm-orchestrator/llm-orchestrator-realm.json).
# VITE_KEYCLOAK_ISSUER=https://keycloak.chilik.net/realms/llm-orchestrator
# VITE_KEYCLOAK_CLIENT_ID=llm-orchestrator-web
