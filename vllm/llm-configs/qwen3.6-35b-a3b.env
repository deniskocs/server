# Конфигурация для Qwen Qwen3.6-35B-A3B (MoE 35B / 3B active, vision+text)
# Рекомендация Qwen: при OOM уменьшить VLLM_MAX_MODEL_LEN (не ниже ~128K для reasoning).
DEFAULT_MODEL_NAME=Qwen/Qwen3.6-35B-A3B
SERVED_MODEL_NAME=Qwen/Qwen3.6-35B-A3B

# Параметры vLLM
VLLM_QUANTIZATION=
VLLM_MAX_MODEL_LEN=262144
VLLM_DTYPE=
VLLM_GPU_MEMORY_UTILIZATION=0.85
# Несколько GPU: задать, например, VLLM_TENSOR_PARALLEL_SIZE=2 или 4
VLLM_TENSOR_PARALLEL_SIZE=
VLLM_REASONING_PARSER=qwen3
VLLM_ENABLE_AUTO_TOOL_CHOICE=true
VLLM_TOOL_CALL_PARSER=llama3_json
