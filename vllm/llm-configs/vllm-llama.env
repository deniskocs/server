# Конфигурация для vLLM Llama FP8 модели
DEFAULT_MODEL_NAME=nvidia/Llama-3.3-70B-Instruct-FP8
SERVED_MODEL_NAME=nvidia/Llama-3.3-70B-Instruct-FP8

# Параметры vLLM
# FP8 модель уже квантованная, quantization не нужен
VLLM_QUANTIZATION=
VLLM_MAX_MODEL_LEN=8192
# dtype не указываем, vLLM автоматически определит тип данных из модели
VLLM_DTYPE=
VLLM_GPU_MEMORY_UTILIZATION=0.95
VLLM_ENABLE_AUTO_TOOL_CHOICE=true
VLLM_TOOL_CALL_PARSER=llama3_json
