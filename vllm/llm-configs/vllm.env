# Конфигурация для vLLM AWQ модели
DEFAULT_MODEL_NAME=ai-automation-finetuned-awq
SERVED_MODEL_NAME=ai-automation-finetuned-awq

# Параметры vLLM
VLLM_QUANTIZATION=awq_marlin
VLLM_MAX_MODEL_LEN=8192
VLLM_DTYPE=float16
VLLM_GPU_MEMORY_UTILIZATION=0.5
VLLM_ENABLE_AUTO_TOOL_CHOICE=true
VLLM_TOOL_CALL_PARSER=llama3_json
