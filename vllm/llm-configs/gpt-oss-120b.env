# Конфигурация для OpenAI GPT-OSS-120B модели
DEFAULT_MODEL_NAME=openai/gpt-oss-120b
SERVED_MODEL_NAME=openai/gpt-oss-120b

# Параметры vLLM
# MoE модель, quantization может быть не нужна или использовать FP8
VLLM_QUANTIZATION=
VLLM_MAX_MODEL_LEN=131072
# dtype не указываем, vLLM автоматически определит тип данных из модели
VLLM_DTYPE=
VLLM_GPU_MEMORY_UTILIZATION=0.88
VLLM_ENABLE_AUTO_TOOL_CHOICE=true
VLLM_TOOL_CALL_PARSER=llama3_json
