DEFAULT_MODEL_NAME=RedHatAI/Qwen3.6-35B-A3B-NVFP4
SERVED_MODEL_NAME=RedHatAI/Qwen3.6-35B-A3B-NVFP4
# Схема NVFP4 лежит в checkpoint (compressed-tensors); отдельный --quantization чаще не нужен — оставь пустым, пока vLLM сам не попросит.
VLLM_QUANTIZATION=
VLLM_MAX_MODEL_LEN=32768
VLLM_DTYPE=
VLLM_GPU_MEMORY_UTILIZATION=0.3
VLLM_TENSOR_PARALLEL_SIZE=
# Как в README модели на HF (эквивалент CLI: --moe-backend flashinfer_cutlass).
VLLM_MOE_BACKEND=flashinfer_cutlass
VLLM_REASONING_PARSER=qwen3
VLLM_ENABLE_AUTO_TOOL_CHOICE=true
VLLM_TOOL_CALL_PARSER=qwen3_coder

HOST=0.0.0.0
PORT=8003
API_KEY=localkey
